# Leave LLM_MODEL empty to auto-pick: small fast model on CPU,
# legal/Arabic 7B on GPU. Override to force a specific model.
LLM_MODEL=
EMBED_MODEL=sentence-transformers/paraphrase-multilingual-mpnet-base-v2
CHROMA_DIR=./chroma_db
WHISPER_MODEL=small
# Leave WHISPER_DEVICE=auto to pick cuda when available.
WHISPER_DEVICE=auto
# Leave WHISPER_COMPUTE empty to pick float16 on GPU, int8 on CPU.
WHISPER_COMPUTE=
DATA_DIR=./data
FORM_TEMPLATE_DIR=./data/forms/templates
FORM_OUTPUT_DIR=./data/forms/filled
LLM_DEVICE=auto
# Lowered from 400 — short, focused legal answers are faster.
LLM_MAX_NEW_TOKENS=256
# 0.0 = greedy decoding (fastest, deterministic). Bump to ~0.3 for variety.
LLM_TEMPERATURE=0.0
